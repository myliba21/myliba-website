# ─────────────────────────────────────────────────────────────
# IMPORTANT: Change ALL passwords below before using this file.
# Run: openssl rand -base64 32  (to generate each password)
# ─────────────────────────────────────────────────────────────
WORDPRESS_PORT=8080

WORDPRESS_DB_NAME=myliba_wp
WORDPRESS_DB_USER=myliba_wp
WORDPRESS_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
WORDPRESS_DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

WORDPRESS_URL=http://localhost:8080
WORDPRESS_TITLE=Myliba
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=change-me-admin
WORDPRESS_ADMIN_EMAIL=admin@example.com

# Hero/banner product screenshots.
# Supports absolute URLs, /wp-content/... paths, or theme-relative paths such as assets/img/hero-focus.png.
# Optional combined format: MYLIBA_HERO_BANNER_IMAGES=https://.../focus.png|https://.../goals.png
MYLIBA_HERO_BANNER_IMAGES=
MYLIBA_HERO_BANNER_IMAGE_1=assets/images/hero-1.png
MYLIBA_HERO_BANNER_IMAGE_2=assets/images/hero-2.png
MYLIBA_HERO_BANNER_ALT_1=Myliba weekly focus dashboard
MYLIBA_HERO_BANNER_ALT_2=Myliba goal map dashboard
